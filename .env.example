# Copy this file to .env and fill in real values. Never commit .env.

# Required. API key for the LLM provider. Sent as a Bearer token; never logged or stored.
EVALKIT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Provider base URL; overrides provider.base_url in evalkit.yaml.
EVALKIT_BASE_URL=https://api.example.com/v1

# Optional. Default model id; overrides provider.model. The --model flag beats this.
EVALKIT_MODEL=example-model-1

# Optional. Judge model id; overrides judge.model. The --judge-model flag beats this.
EVALKIT_JUDGE_MODEL=example-judge-1
